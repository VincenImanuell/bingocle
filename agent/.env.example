# --- Anthropic (AI Curator / Odds / Oracle matching) ---
ANTHROPIC_API_KEY=

# --- Mantle chain ---
# Sepolia testnet (chainId 5003) for the hackathon demo.
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# Agent wallet that signs on-chain txs. This wallet must be:
#   - the registered Oracle operator in AgentIdentity (commitValidation)
#   - the WordPool curator (commitPool)
# Fund it with testnet MNT.
AGENT_PRIVATE_KEY=

# --- Deployed contract addresses (fill after `forge script Deploy`) ---
EVENT_FACTORY_ADDRESS=
WORD_POOL_ADDRESS=
WORD_MARKET_ADDRESS=
ORACLE_REGISTRY_ADDRESS=
BINGO_CARD_NFT_ADDRESS=
REWARD_VAULT_ADDRESS=
AGENT_IDENTITY_ADDRESS=

# --- Service ---
PORT=8787
# Path to Foundry build output (for ABIs). Default resolves to ../contracts/out.
CONTRACTS_OUT=

# --- Speech-to-text (Validation Oracle). Optional: demo runs from a transcript. ---
# Set to enable `npm run oracle:audio <eventId> <audioFile>` (real Whisper STT).
OPENAI_API_KEY=
