# WalletConnect Cloud project id (https://cloud.walletconnect.com)
# Browser-extension wallets work without it; WalletConnect QR wallets need it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Bingocle agent service (word labels + odds for the live market at /play)
NEXT_PUBLIC_AGENT_API=http://localhost:8787

# Deployed contract addresses (set after `forge script Deploy`; scripts/deploy.sh
# writes these into frontend/.env.local automatically).
NEXT_PUBLIC_EVENT_FACTORY=
NEXT_PUBLIC_WORD_POOL=
NEXT_PUBLIC_WORD_MARKET=
NEXT_PUBLIC_ORACLE_REGISTRY=
NEXT_PUBLIC_BINGO_CARD_NFT=
NEXT_PUBLIC_REWARD_VAULT=
