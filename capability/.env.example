# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Bingocle agent service (createEvent / commit-pool / validate / card views)
AGENT_API_URL=http://localhost:8787

# Mantle chain (for per-user demo wallets that buy/claim directly)
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# Master seed for deriving per-user *testnet demo* wallets (one per Telegram user).
# TESTNET DEMO ONLY — never use a mainnet seed here. Web2 onboarding: no seed phrase for users.
DEMO_WALLET_MNEMONIC=

# Deployed contract addresses (same as agent/.env)
EVENT_FACTORY_ADDRESS=
WORD_POOL_ADDRESS=
WORD_MARKET_ADDRESS=
ORACLE_REGISTRY_ADDRESS=
BINGO_CARD_NFT_ADDRESS=
REWARD_VAULT_ADDRESS=
AGENT_IDENTITY_ADDRESS=

# Path to Foundry build output (ABIs). Default resolves to ../contracts/out.
CONTRACTS_OUT=

# --- Email channel (optional second surface; `npm run email`) ---
# Use a dedicated mailbox. Gmail: enable IMAP + use an app password.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
SMTP_HOST=
SMTP_PORT=465
# SMTP_USER / SMTP_PASS default to the IMAP_* values if unset.
EMAIL_FROM=
EMAIL_POLL_MS=15000
