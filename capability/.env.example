# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Bingocle agent service (createEvent / commit-pool / validate / card views).
# In production this MUST be the public HTTPS URL of the hosted agent service,
# not localhost — otherwise organizer/AI actions fail for remote users + Minds.
AGENT_API_URL=http://localhost:8787

# Optional natural-language understanding for free-text chat (same key as agent/).
# Without it, the Capability still works fully via slash/verb commands.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Mantle chain (for per-user demo wallets that buy/claim directly)
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# Master seed for deriving per-user *testnet demo* wallets (one per user).
# TESTNET DEMO ONLY — never use a mainnet seed here. Web2 onboarding: no seed phrase for users.
DEMO_WALLET_MNEMONIC=

# Deployed contract addresses (same as agent/.env). ABIs are embedded (src/abis.ts),
# so no Foundry build / CONTRACTS_OUT path is needed to run the Capability.
EVENT_FACTORY_ADDRESS=
WORD_POOL_ADDRESS=
WORD_MARKET_ADDRESS=
ORACLE_REGISTRY_ADDRESS=
BINGO_CARD_NFT_ADDRESS=
REWARD_VAULT_ADDRESS=
AGENT_IDENTITY_ADDRESS=

# --- Email channel (optional second surface; `npm run email`) ---
# Use a dedicated mailbox. Gmail: enable IMAP + use an app password.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
SMTP_HOST=
SMTP_PORT=465
# SMTP_USER / SMTP_PASS default to the IMAP_* values if unset.
EMAIL_FROM=
EMAIL_POLL_MS=15000
